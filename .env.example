# APEX × FPG — environment variables
# Copy to .env.local for local dev (already gitignored).

# -- APEX session security ---------------------------------------------------
# Used to sign session cookies. Generate with: openssl rand -hex 32
APEX_SESSION_SECRET=dev-session-secret-apex-powered-by-fpg-CHANGE-IN-PRODUCTION

# -- FPG mock OAuth credentials ----------------------------------------------
# APEX uses these to call the FPG API. In production FPG issues them.
FPG_CLIENT_ID=apex_demo
FPG_CLIENT_SECRET=apex_demo_secret_change_in_prod

# -- FPG HMAC secrets --------------------------------------------------------
# Signs FPG mock API responses (X-FPG-Signature header).
FPG_HMAC_SECRET=fpg-response-hmac-DEV-CHANGE-ME

# Signs FPG → APEX webhook events. Must be shared with both sides.
FPG_WEBHOOK_SECRET=fpg-webhook-secret-DEV-CHANGE-ME

# -- Demo behaviour ----------------------------------------------------------
# Set to "false" on Vercel (filesystem is ephemeral; the store re-seeds on cold start).
PERSIST=true

# Frozen "now" for the demo so dates render consistently. Format: ISO 8601 UTC.
NOW=2026-05-25T09:00:00Z

# Where the FPG mock dispatcher sends webhooks. Defaults to localhost.
# On Vercel: https://<your-deployment>.vercel.app/api/internal/webhooks/fpg
APEX_WEBHOOK_URL=http://localhost:3000/api/internal/webhooks/fpg
